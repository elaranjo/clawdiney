# --- Clawdiney Configuration ---

# Path to your Obsidian Vault (The knowledge source)
VAULT_PATH=~/Documents/ObsidianVault
VAULT_MOUNT_PATH=~/Documents/ObsidianVault

# ChromaDB HTTP connection
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Embedding model to use via Ollama
MODEL_NAME=bge-m3:latest

# Optional reranker
ENABLE_RERANK=true
RERANK_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_THRESHOLD=0.5

# Chunking
CHUNKING_STRATEGY=headers
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Neo4j Connection Details
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-password

# Container images
NEO4J_IMAGE=neo4j:latest
CHROMA_IMAGE=chromadb/chroma:latest

# Ollama host for Dockerized MCP server
OLLAMA_HOST=host.docker.internal
