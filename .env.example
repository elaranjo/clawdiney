# --- Clawdiney Multi-Vault Configuration ---

# Lista de vaults (separados por vírgula)
VAULTS=general,projects,personal

# Paths para cada vault
VAULT_GENERAL_PATH=~/clawdiney-vaults/general
VAULT_PROJECTS_PATH=~/clawdiney-vaults/projects
VAULT_PERSONAL_PATH=~/clawdiney-vaults/personal

# Vault padrão usado pelo MCP server
MCP_DEFAULT_VAULT=general

# OU: Descobrir vaults automaticamente de um diretório
# VAULTS_DIR=~/clawdiney-vaults
#
# Cada subpasta com clawdiney.toml vira um vault automaticamente.
# Exemplo de estrutura:
# ~/clawdiney-vaults/
# ├── general/clawdiney.toml
# ├── cliente-alfa/clawdiney.toml
# └── cliente-beta/clawdiney.toml

# ChromaDB HTTP connection
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Embedding model to use via Ollama
MODEL_NAME=bge-m3:latest

# Optional reranker
ENABLE_RERANK=true
RERANK_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_THRESHOLD=0.5

# Chunking
CHUNKING_STRATEGY=headers
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Neo4j Connection Details
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-password

# Container images
NEO4J_IMAGE=neo4j:latest
CHROMA_IMAGE=chromadb/chroma:latest

# Ollama host for Dockerized MCP server
OLLAMA_HOST=host.docker.internal

# Redis (Query Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme  # Change in production!
ENABLE_QUERY_CACHE=true
